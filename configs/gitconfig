# Personal settings go in gitconfig.local (not committed)
# Create it with:
#   [user]
#     name = Your Name
#     email = you@example.com
#     signingkey = YOUR_GPG_KEY
[include]
  path = ~/.gitconfig.local
[alias]
  bra = branch --format="%(refname:short)"
  bugs = commit -m ':bug: A small bugfix or two'
  check = !git status --porcelain | grep "^??" && echo "Warning: Untracked files found!" || echo "No untracked files."
  clean = status --porcelain | grep '^??' | cut -c4- | xargs rm -rf
  co = "!f() { \
    if [ \"$1\" = \"main\" ]; then \
      git checkout main; \
    else \
      mo=$(date +\"%b\" | tr '[:upper:]' '[:lower:]'); \
      day=$(date '+%d'); \
      git checkout -b clark/${mo}-${day}-$1; \
    fi; \
    }; f"
  copilot = "commit -m '🤖 Addresses feedback from our AI Overlords'"
  commitnv = commit --no-verify
  cleanup = commit -m ':bulb: Minor cleanup'
  dead = commit -m ':coffin: Removes old and/or dead code'
  cp = "!f() { \
    if [ -z \"$1\" ]; then \
      echo \"🍒 There are no cherries to pick\"; \
    else \
      git cherry-pick $1; \
    fi; \
    }; f"
  derp = commit -m ':see_no_evil: Whoops'
  docs = commit -m ':pencil2: Adds to documentation, code comments, etc.'
  experiment = commit -m ':test_tube: Experimenting...'
  fa = fetch -a
  hmmm = commit -m ':monocle_face: Debugging things'
  linting = commit -m ':lipstick: Linting fix-ups'
  minor = commit -m 'Minor fixes -- i.e. code consistency, small bugs, tests, documentation'
  vul = commit -m ':closed_lock_with_key: Package updates for vulnerability remediation'
  logs = "!f() { git --no-pager log --oneline | head -n ${1:-10}; }; f"
  oops = reset --hard HEAD
  p = push
  pp = "!git pull && git push"
  recent-tags = "!git fetch --tags --force && git tag --sort=-creatordate --format='%(creatordate:short): %(refname:short)' | head -n 10"
  sha = "rev-parse --short HEAD"
  sha-full = "rev-parse HEAD"
  sp = "!f() { \
    git stash -u && \
    git pull --rebase && \
    git stash pop || true; \
    git add -p; \
    }; f"
  standards = commit -m ':construction_worker: Bring this project up to team standards'
  tests = commit -m ':test_tube: Tests tests tests'
  trigger-ci = commit -m 'chore: trigger ci' --allow-empty
  typo = commit -m ':see_no_evil: Fixes a typo'
  ver-bump = commit -m ':chart_with_upwards_trend: Bumps one or more dependencies'
  wip = commit -m ':safety_vest: This is work in progress'

  # list remote branches that match my naming pattern
  remote-branches = "!git branch -r | grep clark | sed 's|origin/|- |' | while read line; do branch=$(echo $line | sed 's|- ||'); echo \"$line (delete with: git push origin :$branch)\"; done"
  wcpgw = commit -m ':alien: What could possibly go wrong...'
[commit]
  gpgsign = true
[core]
  pager = delta
  editor = vim
  whitespace = fix
  hooksPath = ~/.config/git/hooks
[delta]
  navigate = true
[diff]
  colorMoved = default
[fetch]
  prune = true
[help]
  autocorrect = 1
[interactive]
  diffFilter = delta --color-only
[merge]
  conflictstyle = diff3
[protocol "file"]
  allow = always
[pull]
  rebase = true
[push]
  autoSetupRemote = true
  default = current
[rebase]
  autosquash = true
[safe]
  directory = *
[url "git@github.com:"]
  insteadOf = https://github.com/
